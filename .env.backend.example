# Copy this file to .env.backend.local for local review.
# The Python backend now loads .env.backend.local, .env.providers.local, .env.local, .env.backend, .env.providers, and .env automatically.

GAUSET_ENABLE_PROVIDER_IMAGE_GEN=1

# Optional offline smoke provider for local review.
GAUSET_PROVIDER_MOCK=0

# Google Vertex Imagen
GAUSET_GOOGLE_VERTEX_PROJECT=
GAUSET_GOOGLE_VERTEX_LOCATION=us-central1
GAUSET_GOOGLE_VERTEX_MODEL=imagen-4.0-generate-001
# Choose one Google auth path:
# 1. Run: gcloud auth application-default login
# 2. Or point to a service-account key file:
GAUSET_GOOGLE_SERVICE_ACCOUNT_FILE=
# 3. Or paste service-account JSON directly:
GAUSET_GOOGLE_SERVICE_ACCOUNT_JSON=
# 4. Or inject a short-lived bearer token:
GAUSET_GOOGLE_VERTEX_ACCESS_TOKEN=

# Runway
GAUSET_RUNWAY_API_KEY=
GAUSET_RUNWAY_MODEL=gen4_image
GAUSET_RUNWAY_API_VERSION=2024-11-06
# Force upload-based reference handling when you want to avoid inline data URIs.
GAUSET_RUNWAY_UPLOAD_REFERENCES=0
GAUSET_RUNWAY_INLINE_REFERENCE_MAX_BYTES=4500000

# BytePlus ModelArk / Seedream
GAUSET_BYTEPLUS_API_KEY=
GAUSET_BYTEPLUS_MODEL=seedream-4-5-251128
GAUSET_BYTEPLUS_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
