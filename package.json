{
  "name": "gauset-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:backend": "backend_venv/bin/python backend/server.py",
    "dev:all": "node scripts/dev-all.mjs",
    "verify:boundary": "node scripts/check-deploy-boundary.mjs",
    "build": "node guard-deploy-target.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:mvp": "eslint src/app/mvp src/components/Editor src/lib/mvp*.ts tests/mvp.local.spec.js tests/mvp.public.spec.js scripts/mvp_viewer_diag.mjs scripts/hostile_local_reconstruction_audit.mjs scripts/hostile_public_audit.mjs scripts/generate_benchmark_splat_fixture.mjs scripts/mvp_benchmark_5m.mjs",
    "typecheck": "tsc --noEmit",
    "test:preview": "backend_venv/bin/python -m unittest tests.test_vercel_single_image_preview_fallback tests.test_ml_sharp_preview_enhancement tests.test_mvp_persistence_contracts",
    "closeout:static": "npm run verify:boundary && npm run typecheck && npm run lint:mvp && npm run test:preview && npm run build"
  },
  "dependencies": {
    "@lumaai/luma-web": "^0.2.2",
    "@prisma/client": "^7.4.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "geist": "^1.7.0",
    "lenis": "^1.3.17",
    "lucide-react": "^0.575.0",
    "maath": "^0.10.8",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^7.4.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
